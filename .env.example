# DeepSeek API Configuration (OpenAI Compatible)
DEEPSEEK_API_KEY=tu_clave_api_aqui
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# LLM Model Configuration
LLM_MODEL=deepseek-chat
LLM_SYSTEM_PROMPT="Eres un asistente útil que responde preguntas de manera clara y concisa."
LLM_MAX_TOKENS=500
LLM_TEMPERATURE=0.7
LLM_TIMEOUT_MS=30000

# Advanced LLM Features (Optional)
# LLM_THINKING_ENABLED=false  # Set to "true" to enable thinking mode (requires deepseek-reasoner model)
# LLM_RESPONSE_FORMAT=text    # "text" or "json_object"
# LLM_FREQUENCY_PENALTY=0
# LLM_PRESENCE_PENALTY=0
# LLM_TOP_P=1

# WhatsApp Chat Configuration
INACTIVITY_HOURS_FOR_GREETING=8

# ChromaDB Context Configuration (Optional)
# CONTEXT_FILE_PATH=contexto.txt
# CONTEXT_RESULTS_COUNT=3
# CHROMA_HOST=localhost
# CHROMA_PORT=8000
# CHROMA_SSL=false
# NOTA: Para usar ChromaDB, inicia el servidor en otra terminal con:
# npm run start:chroma  (usa ./chroma_db como directorio de persistencia)
# o npm run start:chroma:getting-started (usa ./getting-started)